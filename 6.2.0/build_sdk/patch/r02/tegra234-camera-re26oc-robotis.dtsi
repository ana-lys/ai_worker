/*
 * Novitec RE26OC
 *
 */

/ {
	fragment-camera@0 {
		target-path = "/";
		__overlay__ {
			tegra-capture-vi {
				num-channels = <6>;
				ports {
					#address-cells = <1>;
					#size-cells = <0>;
					port@0 {
						reg = <0>;
						lire26oc_vi_in0: endpoint {
							port-index = <0>;
							bus-width = <4>;
							vc-id = <0>;
							remote-endpoint = <&lire26oc_csi_out0>;
						};
					};

					port@1 {
						reg = <1>;
						lire26oc_vi_in1: endpoint {
							port-index = <0>;
							bus-width = <4>;
							vc-id = <1>;
							remote-endpoint = <&lire26oc_csi_out1>;
						};
					};

					port@2 {
						reg = <2>;
						lire26oc_vi_in2: endpoint {
							port-index = <2>;
							bus-width = <4>;
							vc-id = <0>;
							remote-endpoint = <&lire26oc_csi_out2>;
						};
					};

					port@3 {
						reg = <3>;
						lire26oc_vi_in3: endpoint {
							port-index = <2>;
							bus-width = <4>;
							vc-id = <1>;
							remote-endpoint = <&lire26oc_csi_out3>;
						};
					};

					port@4 {
						reg = <4>;
						lire26oc_vi_in4: endpoint {
							port-index = <4>;
							bus-width = <4>;
							vc-id = <0>;
							remote-endpoint = <&lire26oc_csi_out4>;
						};
					};

					port@5 {
						reg = <5>;
						lire26oc_vi_in5: endpoint {
							port-index = <4>;
							bus-width = <4>;
							vc-id = <1>;
							remote-endpoint = <&lire26oc_csi_out5>;
						};
					};
				};
			};
		};
	};
	fragment-camera@1 {
		target-path = "/bus@0";
		__overlay__ {
			host1x@13e00000 {
				nvcsi@15a00000 {
					num-channels = <6>;
					#address-cells = <1>;
					#size-cells = <0>;
					channel@0 {
						reg = <0>;
						ports {
							#address-cells = <1>;
							#size-cells = <0>;
							port@0 {
								reg = <0>;
								lire26oc_csi_in0: endpoint@0 {
									port-index = <0>;
									bus-width = <4>;
									remote-endpoint = <&lire26oc_re26oc_out0>;
								};
							};
							port@1 {
								reg = <1>;
								lire26oc_csi_out0: endpoint@1 {
									remote-endpoint = <&lire26oc_vi_in0>;
								};
							};
						};
					};
					channel@1 {
						reg = <1>;
						ports {
							#address-cells = <1>;
							#size-cells = <0>;
							port@0 {
								reg = <0>;
								lire26oc_csi_in1: endpoint@2 {
									port-index = <0>;
									bus-width = <4>;
									remote-endpoint = <&lire26oc_re26oc_out1>;
								};
							};
							port@1 {
								reg = <1>;
								lire26oc_csi_out1: endpoint@3 {
									remote-endpoint = <&lire26oc_vi_in1>;
								};
							};
						};
					};

					channel@2 {
						reg = <2>;
						ports {
							#address-cells = <1>;
							#size-cells = <0>;
							port@0 {
								reg = <0>;
								lire26oc_csi_in2: endpoint@4 {
									port-index = <2>;
									bus-width = <4>;
									remote-endpoint = <&lire26oc_re26oc_out2>;
								};
							};
							port@1 {
								reg = <1>;
								lire26oc_csi_out2: endpoint@5 {
									remote-endpoint = <&lire26oc_vi_in2>;
								};
							};
						};
					};

					channel@3 {
						reg = <3>;
						ports {
							#address-cells = <1>;
							#size-cells = <0>;
							port@0 {
								reg = <0>;
								lire26oc_csi_in3: endpoint@6 {
									port-index = <2>;
									bus-width = <4>;
									remote-endpoint = <&lire26oc_re26oc_out3>;
								};
							};
							port@1 {
								reg = <1>;
								lire26oc_csi_out3: endpoint@7 {
									remote-endpoint = <&lire26oc_vi_in3>;
								};
							};
						};
					};

					channel@4 {
						reg = <4>;
						ports {
							#address-cells = <1>;
							#size-cells = <0>;
							port@0 {
								reg = <0>;
								lire26oc_csi_in4: endpoint@8 {
									port-index = <4>;
									bus-width = <4>;
									remote-endpoint = <&lire26oc_re26oc_out4>;
								};
							};
							port@1 {
								reg = <1>;
								lire26oc_csi_out4: endpoint@9 {
									remote-endpoint = <&lire26oc_vi_in4>;
								};
							};
						};
					};

					channel@5 {
						reg = <5>;
						ports {
							#address-cells = <1>;
							#size-cells = <0>;
							port@0 {
								reg = <0>;
								lire26oc_csi_in5: endpoint@10 {
									port-index = <4>;
									bus-width = <4>;
									remote-endpoint = <&lire26oc_re26oc_out5>;
								};
							};
							port@1 {
								reg = <1>;
								lire26oc_csi_out5: endpoint@11 {
									remote-endpoint = <&lire26oc_vi_in5>;
								};
							};
						};
					};
				};
			};
			
			i2c@3180000 {
				re26oc_f@1f {
					compatible = "sony,imx185";

					reg = <0x1f>;
					devnode = "video5";

					/* Physical dimensions of sensor */
					physical_w = "15.0";
					physical_h = "12.5";

					sensor_model ="re26oc";

					mode0 {
						vc_id = "5";
						mclk_khz = "24000";
						num_lanes = "4";
						tegra_sinterface = "serial_e";
						phy_mode = "DPHY";
						discontinuous_clk = "yes";
						dpcm_enable = "false";
						cil_settletime = "0";
						dynamic_pixel_bit_depth = "16";
						csi_pixel_bit_depth = "16";
						mode_type = "yuv";
						pixel_phase = "uyvy";

						active_w = "1920";
						active_h = "1080";
						readout_orientation = "0";
						line_length = "2200";
						inherent_gain = "1";
						mclk_multiplier = "14";
						pix_clk_hz = "336000000";

						gain_factor = "10";
						min_gain_val = "0"; /* 0dB */
						max_gain_val = "480"; /* 48dB */
						step_gain_val = "3"; /* 0.3 */
						default_gain = "0";
						min_hdr_ratio = "1";
						max_hdr_ratio = "1";
						framerate_factor = "1000000";
						min_framerate = "1500000"; /* 1.5 */
						max_framerate = "60000000"; /* 30 */
						step_framerate = "1";
						default_framerate= "30000000";
						exposure_factor = "1000000";
						min_exp_time = "30"; /* us */
						max_exp_time = "660000"; /* us */
						step_exp_time = "1";
						default_exp_time = "33334";/* us */
						embedded_metadata_height = "0";
					};
					mode1 {
						vc_id = "5";
						mclk_khz = "24000";
						num_lanes = "4";
						tegra_sinterface = "serial_e";
						phy_mode = "DPHY";
						discontinuous_clk = "yes";
						dpcm_enable = "false";
						cil_settletime = "0";
